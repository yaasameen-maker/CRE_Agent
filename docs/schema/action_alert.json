{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "action_alert",
  "title": "Action Alert",
  "description": "Daily alert payload classifying markets as Model / Monitor / Ignore. Frontend reads this for the Alerts view.",
  "type": "object",
  "required": ["generated_at", "alerts"],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "alerts": {
      "type": "array",
      "description": "Sorted: Model first, then Monitor. Ignore-classified ZIPs are omitted.",
      "items": {
        "type": "object",
        "required": ["zip", "action", "distress_score", "primary_signal", "brief_id", "message"],
        "additionalProperties": false,
        "properties": {
          "zip":            { "type": "string", "pattern": "^[0-9]{5}$" },
          "action":         { "type": "string", "enum": ["Model", "Monitor"] },
          "distress_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "primary_signal": {
            "type": "string",
            "enum": ["vacancy", "rent", "price_growth", "employment", "foreclosure"],
            "description": "The single highest-weight flagged signal driving this alert"
          },
          "brief_id": { "type": "string", "format": "uuid" },
          "message":  { "type": "string", "description": "One-sentence human-readable alert summary" }
        }
      }
    }
  }
}
